{
  "name": "openself",
  "version": "0.6.0",
  "description": "Your AI clone. Your messages. Your machine. Open-source AI personality clone that lives in your messaging apps.",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "openself": "./src/cli/index.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": {
      "default": "./src/index.js"
    },
    "./cli": {
      "default": "./src/cli/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "node src/cli/index.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:clone": "node src/cli/index.js test",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "feed": "node src/cli/index.js feed",
    "setup": "node src/cli/index.js setup",
    "arena": "node src/cli/index.js arena",
    "ghost": "node src/cli/index.js ghost",
    "profile": "node src/cli/index.js profile",
    "prepack": "npm run lint && npm test",
    "prepublishOnly": "npm run lint && npm test && npx --yes publint --strict",
    "prepare": "node -e \"try{require('fs').chmodSync('./src/cli/index.js',0o755)}catch{}\""
  },
  "keywords": [
    "ai",
    "clone",
    "personality",
    "whatsapp",
    "telegram",
    "discord",
    "chatbot",
    "llm",
    "openself"
  ],
  "author": "OpenSelf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Open-Self/open-self.git"
  },
  "homepage": "https://github.com/Open-Self/open-self#readme",
  "bugs": {
    "url": "https://github.com/Open-Self/open-self/issues"
  },
  "files": [
    "src/",
    "SOUL.md.example",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "discord.js": {
      "undici": "^6.27.0"
    },
    "@discordjs/rest": {
      "undici": "^6.27.0"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@whiskeysockets/baileys": "^6.7.23",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "grammy": "^1.44.0",
    "inquirer": "^14.0.2",
    "openai": "^6.45.0",
    "ora": "^9.4.1",
    "qrcode-terminal": "^0.12.0",
    "update-notifier": "^7.3.1",
    "vectra": "^0.15.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "vitest": "^4.1.10"
  }
}
